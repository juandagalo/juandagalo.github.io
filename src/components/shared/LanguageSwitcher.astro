---
import { languages, type Lang } from "@/i18n/ui";
import { getLangFromUrl, getPathWithoutLang } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const currentLang = getLangFromUrl(Astro.url);
const currentPath = getPathWithoutLang(Astro.url.pathname);
---

<div class="relative group">
  <button
    type="button"
    class="text-sm text-gray-600 hover:text-gray-900 cursor-pointer"
  >
    {languages[currentLang]}
  </button>
  <div
    class="hidden group-hover:block absolute right-0 top-full mt-1 bg-white border border-gray-200 rounded shadow-sm min-w-[120px] z-50"
  >
    {
      Object.entries(languages).map(([code, label]) => (
        <a
          href={getRelativeLocaleUrl(code as Lang, currentPath)}
          class:list={[
            "block px-4 py-2 text-sm hover:bg-gray-100 transition-colors",
            code === currentLang
              ? "text-gray-900 font-medium"
              : "text-gray-600",
          ]}
        >
          {label}
        </a>
      ))
    }
  </div>
</div>
