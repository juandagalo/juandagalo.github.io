---
import { languages, type Lang } from "@/i18n/ui";
import { getLangFromUrl, getPathWithoutLang } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const currentLang = getLangFromUrl(Astro.url);
const currentPath = getPathWithoutLang(Astro.url.pathname);
---

<div class="relative group">
  <button
    type="button"
    class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 cursor-pointer"
  >
    {languages[currentLang]}
  </button>
  <div
    class="hidden group-hover:block group-focus-within:block absolute right-0 top-full pt-1 z-50"
  >
    <div
      class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded shadow-sm min-w-[120px]"
    >
      {
        Object.entries(languages).map(([code, label]) => (
          <a
            href={getRelativeLocaleUrl(code as Lang, currentPath)}
            class:list={[
              "block px-4 py-2 text-sm hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors",
              code === currentLang
                ? "text-gray-900 dark:text-gray-100 font-medium"
                : "text-gray-600 dark:text-gray-400",
            ]}
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</div>
