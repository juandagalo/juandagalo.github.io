<template id="projects-skeleton">
  <section class="mx-auto max-w-5xl px-4 py-20">
    <!-- Page title skeleton -->
    <div
      class="mb-12 h-10 w-48 animate-pulse rounded bg-gray-200 dark:bg-gray-800"
    >
    </div>

    <!-- Featured section title skeleton -->
    <div class="mb-6">
      <div class="h-7 w-32 animate-pulse rounded bg-gray-200 dark:bg-gray-800">
      </div>
      <span class="mt-2 block h-1 w-12 bg-orange-600 dark:bg-orange-500"></span>
    </div>

    <!-- Featured grid: 2 cards -->
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        Array.from({ length: 2 }).map(() => (
          <div class="rounded-lg border border-l-4 border-gray-200 border-l-orange-600 bg-white p-6 dark:border-gray-800 dark:border-l-orange-500 dark:bg-gray-900">
            {/* Title + stars row */}
            <div class="flex items-start justify-between gap-3">
              <div class="h-6 w-40 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              <div class="h-5 w-16 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
            </div>
            {/* Description: 2 lines */}
            <div class="mt-2 space-y-2">
              <div class="h-4 w-full animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              <div class="h-4 w-3/4 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
            </div>
            {/* Highlights list */}
            <div class="mt-3 space-y-2">
              <div class="h-4 w-5/6 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              <div class="h-4 w-4/6 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              <div class="h-4 w-3/6 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
            </div>
            {/* Tags */}
            <div class="mt-3 flex flex-wrap items-center gap-2">
              <div class="h-5 w-14 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              <div class="h-5 w-18 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              <div class="h-5 w-12 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
            </div>
          </div>
        ))
      }
    </div>

    <!-- Other section -->
    <div class="mt-16">
      <!-- Section title skeleton -->
      <div class="mb-6">
        <div
          class="h-7 w-28 animate-pulse rounded bg-gray-200 dark:bg-gray-800"
        >
        </div>
        <span class="mt-2 block h-1 w-12 bg-orange-600 dark:bg-orange-500"
        ></span>
      </div>

      <!-- Compact grid: 3 cards -->
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          Array.from({ length: 3 }).map(() => (
            <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
              {/* Title + stars row */}
              <div class="flex items-start justify-between gap-3">
                <div class="h-5 w-32 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
                <div class="h-5 w-12 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              </div>
              {/* Description: 1 line */}
              <div class="mt-2">
                <div class="h-4 w-full animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              </div>
              {/* Language badge */}
              <div class="mt-3">
                <div class="h-5 w-16 animate-pulse rounded bg-gray-200 dark:bg-gray-800" />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</template>

<script>
  import type { TransitionBeforePreparationEvent } from "astro:transitions/client";

  document.addEventListener("astro:before-preparation", (e) => {
    const event = e as TransitionBeforePreparationEvent;
    const url = event.to;
    if (/^\/(es\/)?projects\/?$/.test(url.pathname)) {
      const main = document.querySelector("main");
      const tpl = document.getElementById(
        "projects-skeleton",
      ) as HTMLTemplateElement | null;
      if (main && tpl) {
        main.innerHTML = "";
        main.appendChild(tpl.content.cloneNode(true));
      }
    }
  });
</script>
