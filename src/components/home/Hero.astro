---
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="mx-auto max-w-5xl px-4 py-24 md:py-32">
  <p class="text-lg text-gray-500 dark:text-gray-400">{t("hero.greeting")}</p>
  <h1
    class="text-5xl md:text-6xl font-bold mt-2 text-gray-900 dark:text-gray-100"
  >
    {t("hero.name")}
  </h1>
  <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mt-4">
    {t("hero.tagline")}
  </p>
  <div class="mt-8 flex flex-wrap gap-4">
    <a
      href={getRelativeLocaleUrl(lang, "/projects")}
      class="inline-block px-6 py-3 text-sm font-medium rounded-lg bg-orange-600 text-white hover:bg-orange-700 dark:bg-orange-500 dark:hover:bg-orange-600 transition-colors"
    >
      {t("hero.cta.projects")}
    </a>
    <a
      href={getRelativeLocaleUrl(lang, "/blog")}
      class="inline-block px-6 py-3 text-sm font-medium rounded-lg border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-orange-600 dark:hover:border-orange-500 hover:text-orange-600 dark:hover:text-orange-500 transition-colors"
    >
      {t("hero.cta.blog")}
    </a>
  </div>
</section>
