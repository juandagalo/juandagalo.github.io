---
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";
import LanguageSwitcher from "@/components/shared/LanguageSwitcher.astro";
import ThemeToggle from "@/components/shared/ThemeToggle.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: getRelativeLocaleUrl(lang, "/"), label: t("nav.home") },
  {
    href: getRelativeLocaleUrl(lang, "/projects"),
    label: t("nav.projects"),
  },
  { href: getRelativeLocaleUrl(lang, "/blog"), label: t("nav.blog") },
  { href: getRelativeLocaleUrl(lang, "/about"), label: t("nav.about") },
];
---

<header class="border-b border-gray-200 dark:border-gray-800">
  <nav class="mx-auto max-w-5xl px-4 py-4 flex items-center justify-between">
    <a href={getRelativeLocaleUrl(lang, "/")} class="text-xl font-bold">
      JDL
    </a>

    <input type="checkbox" id="menu-toggle" class="hidden peer" />
    <label
      for="menu-toggle"
      class="md:hidden cursor-pointer flex flex-col gap-1.5"
      aria-label={t("nav.toggleMenu")}
    >
      <span class="block w-6 h-0.5 bg-gray-900 dark:bg-gray-100"></span>
      <span class="block w-6 h-0.5 bg-gray-900 dark:bg-gray-100"></span>
      <span class="block w-6 h-0.5 bg-gray-900 dark:bg-gray-100"></span>
    </label>

    <div
      class="hidden peer-checked:flex md:flex flex-col md:flex-row items-center gap-6 absolute md:static top-16 left-0 right-0 bg-white dark:bg-gray-950 md:bg-transparent border-b md:border-0 border-gray-200 dark:border-gray-800 px-4 md:px-0 py-4 md:py-0 z-50"
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "transition-colors",
              Astro.url.pathname === link.href ||
              Astro.url.pathname === link.href.replace(/\/$/, "")
                ? "text-orange-500 dark:text-orange-500 font-medium border-b-2 border-orange-500"
                : "text-gray-600 dark:text-gray-400 hover:text-orange-600 dark:hover:text-orange-500",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <LanguageSwitcher />
      <ThemeToggle lang={lang} />
    </div>
  </nav>
</header>
