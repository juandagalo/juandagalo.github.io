---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { useTranslations } from "@/i18n/utils";

const t = useTranslations("es");
---

<BaseLayout title={t("hero.name")} description={t("hero.tagline")} lang="es">
  <section class="mx-auto max-w-5xl px-4 py-20">
    <p class="text-lg text-gray-500">{t("hero.greeting")}</p>
    <h1 class="text-4xl font-bold mt-2">{t("hero.name")}</h1>
    <p class="text-xl text-gray-600 mt-4">{t("hero.tagline")}</p>
  </section>
</BaseLayout>
